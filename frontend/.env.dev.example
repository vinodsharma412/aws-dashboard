# ─────────────────────────────────────────────────────────────────────────────
# NSE Stock Dashboard — DEV stage build template
#
# Use this when building the React app locally to test against the DEV EC2.
#
# Steps:
#   cp frontend/.env.dev.example frontend/.env.local
#   nano frontend/.env.local          ← replace EC2_IP with actual IP
#   cd frontend && npm run build      ← or: npm start (to run dev server)
#
# In CI (GitHub Actions deploy-dev.yml), these values come from GitHub Secrets:
#   DEV_API_URL  → REACT_APP_API_URL
#   DEV_SSE_URL  → REACT_APP_SSE_URL
# ─────────────────────────────────────────────────────────────────────────────

REACT_APP_STAGE=dev

# Dev FastAPI — via Nginx path prefix /dev/api/ → port 9001 on EC2
REACT_APP_API_URL=http://YOUR_EC2_IP/dev/api/v1

# SSE must use direct port access (long-lived connection, no Nginx buffering)
REACT_APP_SSE_URL=http://YOUR_EC2_IP:9001

# S3 bucket for manual frontend deploy (optional, CI handles this automatically)
S3_FRONTEND_BUCKET=nse-frontend-YOUR_ACCOUNT_ID-dev
