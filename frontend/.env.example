# ─────────────────────────────────────────────────────────────────────────────
# NSE Stock Dashboard — Frontend environment template (PRODUCTION)
#
# Copy to .env and fill in your values:
#   cp frontend/.env.example frontend/.env
#
# .env is gitignored — NEVER commit this file.
#
# ── Stage overview ───────────────────────────────────────────────────────────
# Stage   | npm start / build    | Template file
# --------|----------------------|------------------------------
# local   | npm start            | .env.development  (auto-loaded)
# dev     | npm run build        | .env.dev.example → .env.local
# qc      | npm run build        | .env.qc.example  → .env.local
# prod    | npm run build        | .env.example     → .env
#
# In CI (GitHub Actions), env vars are injected directly — no .env file needed.
#
# ── Port / path reference ────────────────────────────────────────────────────
# Stage  | API path (via Nginx 80)  | Direct port | SSE port
# -------|-------------------------|-------------|----------
# prod   | /api/v1                 | :9000       | :9000
# dev    | /dev/api/v1             | :9001       | :9001
# qc     | /qc/api/v1             | :9002       | :9002
# local  | localhost:9000/api/v1   | :9000       | :9000
# ─────────────────────────────────────────────────────────────────────────────

REACT_APP_STAGE=prod

# All REST calls (login, stocks, portfolio) — via Nginx reverse proxy on port 80.
# Option A (API Gateway): https://YOUR_API_GW_ID.execute-api.ap-south-1.amazonaws.com/prod/api/v1
# Option B (direct EC2):  http://YOUR_EC2_PUBLIC_IP/api/v1
REACT_APP_API_URL=http://YOUR_EC2_PUBLIC_IP/api/v1

# SSE streaming (scraping job progress) — MUST point directly to EC2.
# API Gateway has a 29-second timeout that breaks long-running SSE connections.
REACT_APP_SSE_URL=http://YOUR_EC2_PUBLIC_IP

# S3 bucket used by infrastructure/scripts/frontend_deploy.sh
# Found in: AWS Console → S3 → bucket name starts with nse-frontend-
S3_FRONTEND_BUCKET=nse-frontend-YOUR_ACCOUNT_ID

# CloudFront distribution ID (optional — uncomment to invalidate CDN on deploy)
# CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXXX
