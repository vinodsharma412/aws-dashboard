# ─────────────────────────────────────────────────────────────────────────────
# NSE Stock Dashboard — QC stage build template
#
# Use this when building the React app locally to test against the QC EC2.
#
# Steps:
#   cp frontend/.env.qc.example frontend/.env.local
#   nano frontend/.env.local          ← replace EC2_IP with actual IP
#   cd frontend && npm run build
#
# In CI (GitHub Actions deploy-qc.yml), these values come from GitHub Secrets:
#   QC_API_URL  → REACT_APP_API_URL
#   QC_SSE_URL  → REACT_APP_SSE_URL
# ─────────────────────────────────────────────────────────────────────────────

REACT_APP_STAGE=qc

# QC FastAPI — via Nginx path prefix /qc/api/ → port 9002 on EC2
REACT_APP_API_URL=http://YOUR_EC2_IP/qc/api/v1

# SSE must use direct port access (long-lived connection, no Nginx buffering)
REACT_APP_SSE_URL=http://YOUR_EC2_IP:9002

# S3 bucket for manual frontend deploy (optional, CI handles this automatically)
S3_FRONTEND_BUCKET=nse-frontend-YOUR_ACCOUNT_ID-qc
